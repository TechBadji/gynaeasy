generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String          @id @default(cuid())
  name              String?
  email             String?         @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  role              Role            @default(MEDECIN)
  twoFactorEnabled  Boolean         @default(false)
  twoFactorSecret   String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  specialite        String?
  enabledModules    String[]        @default(["AGENDA", "PATIENTS"])
  clinicName        String?
  status            AccountStatus   @default(ACTIVE)
  verificationToken String?         @unique
  abonnements       Abonnement[]
  accessRequests    AccessRequest[]
  consultations     Consultation[]
  auditLogs         AuditLog[]
  asTreating        Patient[]       @relation("TreatingDoctor")
  patients          Patient[]
  facturesHote      FactureHote[]
}

model Patient {
  id                  String          @id @default(cuid())
  codePatient         String          @unique
  civilite            Civilite
  nom                 String
  prenom              String
  dateNaissance       DateTime
  telephone           String?
  email               String?
  adresse             String?
  groupeSanguin       String?
  rhesus              String?
  antecedentsMedicaux Json?
  traitementsEnCours  String?
  isPublic            Boolean         @default(false)
  treatingDoctorId    String
  consentementRGPD    Boolean         @default(false)
  consentementDate    DateTime?
  userId              String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  accessRequests      AccessRequest[]
  consultations       Consultation[]
  documents           Document[]
  grossesses          Grossesse[]
  treatingDoctor      User            @relation("TreatingDoctor", fields: [treatingDoctorId], references: [id])
  user                User?           @relation(fields: [userId], references: [id])
}

model AccessRequest {
  id        String       @id @default(cuid())
  patientId String
  doctorId  String
  status    AccessStatus @default(PENDING)
  expiresAt DateTime?
  createdAt DateTime     @default(now())
  doctor    User         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient   Patient      @relation(fields: [patientId], references: [id])
}

model Grossesse {
  id        String          @id @default(cuid())
  patientId String
  ddr       DateTime?
  dpa       DateTime?
  statut    StatutGrossesse @default(EN_COURS)
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  patient   Patient         @relation(fields: [patientId], references: [id])

  @@index([patientId])
}

model ActeCCAM {
  id            String             @id @default(cuid())
  code          String             @unique
  libelle       String
  description   String?
  tarif         Float
  coeff         Float?
  chapitre      String?
  active        Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  consultations ConsultationActe[]
}

model Consultation {
  id               String             @id @default(cuid())
  patientId        String
  userId           String
  dateHeure        DateTime
  duree            Int                @default(30)
  type             TypeRDV
  motif            String?
  diagnostique     String?
  notes            String?
  donneesMedicales Json?
  honoraire        Float?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  source           RDVSource          @default(PHONE)
  smsReminded      Boolean            @default(false)
  patient          Patient            @relation(fields: [patientId], references: [id])
  user             User               @relation(fields: [userId], references: [id])
  actes            ConsultationActe[]
  reglement        Reglement?

  @@index([patientId])
  @@index([userId])
  @@index([dateHeure])
}

model ConsultationActe {
  id             String       @id @default(cuid())
  consultationId String
  acteId         String
  quantite       Int          @default(1)
  tarifApplique  Float
  coefficient    Float?
  remboursement  Float?
  createdAt      DateTime     @default(now())
  acte           ActeCCAM     @relation(fields: [acteId], references: [id])
  consultation   Consultation @relation(fields: [consultationId], references: [id])

  @@unique([consultationId, acteId])
}

model Reglement {
  id              String         @id @default(cuid())
  consultationId  String         @unique
  montant         Float
  mode            ModePaiement
  statut          StatutPaiement @default(EN_ATTENTE)
  dateReglement   DateTime?
  reference       String?
  feuilleSoinsUrl String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  consultation    Consultation   @relation(fields: [consultationId], references: [id])
}

model Document {
  id          String       @id @default(cuid())
  patientId   String
  nom         String
  type        TypeDocument
  url         String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  description String?
  metadata    Json?
  patient     Patient      @relation(fields: [patientId], references: [id])

  @@index([patientId])
}

model ModeleDocument {
  id        String       @id @default(cuid())
  nom       String
  type      TypeDocument
  contenu   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  patientId String?
  details   String?
  ipAddress String?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([patientId])
  @@index([timestamp])
}

model Abonnement {
  id              String           @id @default(cuid())
  userId          String
  stripeId        String?          @unique
  plan            PlanAbonnement
  statut          StatutAbonnement @default(ACTIF)
  dateDebut       DateTime         @default(now())
  dateFin         DateTime?
  reductionType   ReductionType?
  reductionValeur Float?
  notesPromo      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FactureHote {
  id               String   @id @default(cuid())
  userId           String
  numero           String   @unique // ex: FA-2024-001
  periodeDebut     DateTime
  periodeFin       DateTime
  montantHT        Float
  montantTVA       Float    @default(0)
  montantTTC       Float
  statut           StatutFacture @default(PAYEE)
  url              String?  // PDF stocké
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum StatutFacture {
  EN_ATTENTE
  PAYEE
  ANNULEE
}

model PlanConfig {
  id            String         @id @default(cuid())
  plan          PlanAbonnement @unique
  prixMensuel   Float
  description   String?
  features      Json?
  isPromotional Boolean        @default(false)
  updatedAt     DateTime       @updatedAt
}

model Promotion {
  id          String        @id @default(cuid())
  code        String        @unique
  description String?
  type        ReductionType
  valeur      Float
  validUntil  DateTime?
  usageLimit  Int?
  usageCount  Int           @default(0)
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
}

model StockItem {
  id            String   @id @default(cuid())
  nom           String
  categorie     String?
  quantite      Int      @default(0)
  unite         String   @default("UNITE")
  seuilAlerte   Int      @default(5)
  derniereModif DateTime @updatedAt
  createdAt     DateTime @default(now())
}

model ClinicSettings {
  id        String   @id @default("singleton")
  nom       String   @default("Gynaeasy Clinic")
  adresse   String?
  telephone String?
  email     String?
  slogan    String?
  updatedAt DateTime @updatedAt
}

enum Role {
  MEDECIN
  SECRETAIRE
  ADMIN
}

enum AccountStatus {
  PENDING_VERIFICATION
  PENDING_APPROVAL
  ACTIVE
  BLOCKED
}

enum Civilite {
  MME
  MLLE
  M
}

enum AccessStatus {
  PENDING
  GRANTED
  DENIED
}

enum StatutGrossesse {
  EN_COURS
  TERMINEE
  ARRETEE
}

enum TypeRDV {
  CONSULTATION
  ECHOGRAPHIE
  URGENCE
  SUIVI_GROSSESSE
  TELECONSULTATION
}

enum RDVSource {
  ONLINE
  PHONE
}

enum ModePaiement {
  ESPECES
  CHEQUE
  CB
  VIREMENT
  SANTE
  WAVE
  ORANGE_MONEY
}

enum StatutPaiement {
  EN_ATTENTE
  PAYE
  ANNULE
  REMBOURSE
}

enum TypeDocument {
  ORDONNANCE
  CERTIFICAT
  COURRIER
  RESULTAT_LABO
  ECHOGRAPHIE
  FEUILLE_SOIN
  AUTRE
}

enum ReductionType {
  POURCENTAGE
  MONTANT_FIXE
}

enum PlanAbonnement {
  BASIQUE
  PRO
  PREMIUM
}

enum StatutAbonnement {
  ACTIF
  ANNULE
  EXPIRE
}
