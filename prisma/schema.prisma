// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// UTILISATEURS & AUTHENTIFICATION
// ==========================================

enum Role {
  MEDECIN
  SECRETAIRE
  ADMIN
}

enum AccountStatus {
  PENDING_VERIFICATION
  PENDING_APPROVAL
  ACTIVE
  BLOCKED
}

model User {
  id               String       @id @default(cuid())
  name             String?
  email            String?      @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             Role         @default(MEDECIN)
  status           AccountStatus @default(ACTIVE) // Default active for seeded users
  clinicName       String?      // Name of the clinic/cabinet
  specialite       String?      // Spécialité médicale (ex: Gynécologue, Échographiste)
  enabledModules   String[]     @default(["AGENDA", "PATIENTS"]) // Modules activés par le SuperAdmin
  verificationToken String?      @unique
  twoFactorEnabled Boolean      @default(false)
  twoFactorSecret  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  patients         Patient[]
  asTreating       Patient[]    @relation("TreatingDoctor")
  consultations    Consultation[]
  abonnements      Abonnement[]
  accessRequests   AccessRequest[]
}

// ==========================================
// PATIENTS & DOSSIER MEDICAL
// ==========================================

enum Civilite {
  MME
  MLLE
  M
}

model Patient {
  id                    String         @id @default(cuid())
  codePatient           String         @unique // Code à 5 chiffres unique
  civilite              Civilite
  nom                   String
  prenom                String
  dateNaissance         DateTime
  telephone             String?
  email                 String?
  adresse               String?
  groupeSanguin         String?        // A, B, AB, O
  rhesus                String?        // +, -
  antecedentsMedicaux   Json?          // stocké en JSON pour flexibilité (médicaux, chirurgicaux, familiaux)
  traitementsEnCours    String?
  
  // Confidentialité & Accès
  isPublic              Boolean        @default(false)
  treatingDoctorId      String         // Médecin traitant d'origine
  treatingDoctor        User           @relation("TreatingDoctor", fields: [treatingDoctorId], references: [id])
  
  consentementRGPD      Boolean        @default(false)
  consentementDate      DateTime?
  
  userId                String?        // Créateur (peut être différent du médecin traitant)
  user                  User?          @relation(fields: [userId], references: [id])
  
  consultations         Consultation[]
  grossesses            Grossesse[]
  documents             Document[]
  accessRequests        AccessRequest[]
  
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model AccessRequest {
  id              String         @id @default(cuid())
  patientId       String
  patient         Patient        @relation(fields: [patientId], references: [id])
  doctorId        String         // Le médecin qui demande l'accès
  doctor          User           @relation(fields: [doctorId], references: [id])
  status          AccessStatus   @default(PENDING)
  expiresAt       DateTime?
  createdAt       DateTime       @default(now())
}

enum AccessStatus {
  PENDING
  GRANTED
  DENIED
}

// ==========================================
// SUIVI DE GROSSESSE
// ==========================================

model Grossesse {
  id              String          @id @default(cuid())
  patientId       String
  patient         Patient         @relation(fields: [patientId], references: [id])
  ddr             DateTime?       // Date des Dernières Règles
  dpa             DateTime?       // Date Prévue d'Accouchement (basée sur DDR + calcul classique)
  statut          StatutGrossesse @default(EN_COURS)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([patientId])
}

enum StatutGrossesse {
  EN_COURS
  TERMINEE
  ARRETEE
}

// ==========================================
// CONSULTATIONS & ACTES CCAM
// ==========================================

enum TypeRDV {
  CONSULTATION
  ECHOGRAPHIE
  URGENCE
  SUIVI_GROSSESSE
  TELECONSULTATION
}

// Actes CCAM (importés depuis la base officielle)
model ActeCCAM {
  id          String   @id @default(cuid())
  code        String   @unique // ex: "JQMD001"
  libelle     String   // ex: "Échographie de dépistage du 1er trimestre de grossesse"
  description String?
  tarif       Float    // tarif de base en FCFA
  coeff       Float?   // coefficient éventuel
  chapitre    String?  // ex: "Obstétrique"
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  consultations ConsultationActe[] // Relation modifiée pour pointer vers la table jointe
}

// Consultation enrichie
model Consultation {
  id              String             @id @default(cuid())
  patientId       String
  patient         Patient            @relation(fields: [patientId], references: [id])
  userId          String
  user            User               @relation(fields: [userId], references: [id])
  dateHeure       DateTime
  duree           Int                @default(30)
  type            TypeRDV
  motif           String?            // motif de la consultation
  diagnostique    String?            // code CIM-10 ou texte libre
  notes           String?
  donneesMedicales Json?             // Données structurées (constantes, examen, écho, prescription)
  actes           ConsultationActe[] // actes CCAM réalisés
  honoraire       Float?             // montant total facturé calculé via CCAM
  reglement       Reglement?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  source          RDVSource          @default(PHONE)

  @@index([patientId])
  @@index([userId])
  @@index([dateHeure])
}

enum RDVSource {
  ONLINE
  PHONE
}

// Actes réalisés pendant une consultation
model ConsultationActe {
  id              String        @id @default(cuid())
  consultationId  String
  consultation    Consultation  @relation(fields: [consultationId], references: [id])
  acteId          String
  acte            ActeCCAM      @relation(fields: [acteId], references: [id])
  quantite        Int           @default(1)
  tarifApplique   Float         // tarif au moment de l'acte
  coefficient     Float?        // coefficient appliqué
  remboursement   Float?        // part remboursée
  createdAt       DateTime      @default(now())

  @@unique([consultationId, acteId])
}

// ==========================================
// FACTURATION & RÈGLEMENTS
// ==========================================

model Reglement {
  id              String         @id @default(cuid())
  consultationId  String         @unique
  consultation    Consultation   @relation(fields: [consultationId], references: [id])
  montant         Float
  mode            ModePaiement
  statut          StatutPaiement @default(EN_ATTENTE)
  dateReglement   DateTime?
  reference       String?        // numéro de transaction ou de chèque
  feuilleSoinsUrl String?        // PDF généré de la feuille de soins
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

enum ModePaiement {
  ESPECES
  CHEQUE
  CB
  VIREMENT
  SANTE          // Tiers-payant, Mutuelle
  WAVE           // Mobile Money
  ORANGE_MONEY   // Mobile Money
}

enum StatutPaiement {
  EN_ATTENTE
  PAYE
  ANNULE
  REMBOURSE
}

// ==========================================
// DOCUMENTS & MODÈLES
// ==========================================

model Document {
  id              String        @id @default(cuid())
  patientId       String
  patient         Patient       @relation(fields: [patientId], references: [id])
  nom             String
  type            TypeDocument
  url             String        // URL sur Uploadthing ou autre CDN
  description     String?       // Conclusion ou notes brèves
  metadata        Json?         // Données structurées du compte-rendu
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([patientId])
}

enum TypeDocument {
  ORDONNANCE
  CERTIFICAT
  COURRIER
  RESULTAT_LABO
  ECHOGRAPHIE
  FEUILLE_SOIN
  AUTRE
}

model ModeleDocument {
  id          String        @id @default(cuid())
  nom         String
  type        TypeDocument
  contenu     String        // Contenu avec variables (ex: {{patient_nom}}, {{date_jour}})
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// ==========================================
// SÉCURITÉ & AUDIT LOG (HDS READY)
// ==========================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // ex: "CONSULTATION_DOSSIER", "MODIFICATION_ORDONNANCE", "FACTURATION", "CONNEXION_ECHOUEE"
  patientId String?
  details   String?  // JSON avec les détails (ex: IP, actes modifiés)
  ipAddress String?  // pour traçabilité (IP du navigateur)
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([patientId])
  @@index([timestamp])
}

// ==========================================
// GESTION SAAS (STRIPE / ABONNEMENTS)
// ==========================================

model Abonnement {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  stripeId        String?          @unique  // ID de l'abonnement Stripe
  plan            PlanAbonnement
  statut          StatutAbonnement @default(ACTIF)
  dateDebut       DateTime         @default(now())
  dateFin         DateTime?        // null si abonnement à vie / sans fin prevue
  
  // Gestion des réductions
  reductionType   ReductionType?   // POURCENTAGE ou MONTANT_FIXE
  reductionValeur Float?           // ex: 20 pour 20% ou 5000 pour 5000 FCFA
  notesPromo      String?          // Justification de la promo
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum ReductionType {
  POURCENTAGE
  MONTANT_FIXE
}

// Configuration des plans par le Super Admin
model PlanConfig {
  id              String           @id @default(cuid())
  plan            PlanAbonnement   @unique
  prixMensuel     Float            // Prix standard
  description     String?
  features        Json?            // ["AGENDA", "FACTURATION", "CONSULTATION_ENRICHIE", etc.]
  isPromotional   Boolean          @default(false)
  updatedAt       DateTime         @updatedAt
}

// Bibliothèque de codes promotionnels
model Promotion {
  id              String           @id @default(cuid())
  code            String           @unique
  description     String?
  type            ReductionType
  valeur          Float
  validUntil      DateTime?
  usageLimit      Int?             // Facultatif
  usageCount      Int              @default(0)
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
}

enum PlanAbonnement {
  BASIQUE
  PRO
  PREMIUM
}

enum StatutAbonnement {
  ACTIF
  ANNULE
  EXPIRE
}

// ==========================================
// STOCKS & INVENTAIRE
// ==========================================

model StockItem {
  id            String   @id @default(cuid())
  nom           String   // ex: "Gel échographie", "Papier thermique"
  categorie     String?  // Sanitaire, Imagerie, Bureau
  quantite      Int      @default(0)
  unite         String   @default("UNITE") // FLACON, ROULEAU, BOITE
  seuilAlerte   Int      @default(5)
  derniereModif DateTime @updatedAt
  createdAt     DateTime @default(now())
}

// ==========================================
// CONFIGURATION DU CABINET
// ==========================================

model ClinicSettings {
  id          String   @id @default("singleton")
  nom         String   @default("Gynaeasy Clinic")
  adresse     String?
  telephone   String?
  email       String?
  slogan      String?
  updatedAt   DateTime @updatedAt
}
