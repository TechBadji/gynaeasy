# Configuration de la base de données (ex: Supabase, Neon, ou local Docker)
DATABASE_URL="postgresql://user:password@host:port/gynaeasy?sslmode=require"

# Clé de chiffrement pour les données médicales (AES-256)
# Génère une chaîne hex de 64 caractères : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="remplacer_par_une_cle_securisee"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="une_chaine_tres_securisee_pour_jwt"

# Twilio SMS (Optionnel pour les rappels)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
